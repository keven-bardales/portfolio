# Site URL — used server-side in metadata, sitemap, OG image absolute URLs.
SITE_URL="http://localhost:3000"

# Resend (https://resend.com) — leave unset to fall back to ConsoleMailService.
RESEND_API_KEY=""

# Sender (must be a verified domain in Resend for production)
CONTACT_FROM_EMAIL="onboarding@resend.dev"

# Recipient (where contact form messages are delivered)
CONTACT_TO_EMAIL="keven.bardales@gmail.com"
